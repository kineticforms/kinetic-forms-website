---
const links = [
  { href: "/research", label: "Research" },
  { href: "/tools", label: "Tools" },
  { href: "/about", label: "About" },
];
---

<footer class="py-8 border-t border-zinc-200 dark:border-zinc-800 px-6 bg-white dark:bg-black relative z-10">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <div class="w-5 h-5 bg-black dark:bg-white rounded-[2px] flex items-center justify-center">
        <span class="text-white dark:text-black font-bold text-[8px]">K.</span>
      </div>
      <span class="text-sm font-semibold">Kinetic Forms</span>
    </div>

    <div class="flex items-center gap-6">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class="text-xs text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors focus-visible:ring-2 ring-zinc-900 dark:ring-white rounded-sm"
        >
          {label}
        </a>
      ))}
    </div>

    <p class="text-zinc-500 text-xs tracking-wide uppercase font-medium">
      &copy; {new Date().getFullYear()} Kinetic Forms
    </p>
  </div>
</footer>
