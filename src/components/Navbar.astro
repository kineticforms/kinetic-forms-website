---
const pathname = Astro.url.pathname;

const links = [
  { href: "/research", label: "Research" },
  { href: "/tools", label: "Tools" },
  { href: "/about", label: "About" },
];
---

<nav
  class="fixed top-0 w-full z-50 border-b border-zinc-200 dark:border-zinc-800 bg-white/80 dark:bg-black/80 backdrop-blur-md px-6 py-4"
>
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 focus-visible:ring-2 ring-zinc-900 dark:ring-white rounded-sm">
      <div class="w-8 h-8 bg-black dark:bg-white rounded-sm flex items-center justify-center">
        <span class="text-white dark:text-black font-bold text-xs">K.</span>
      </div>
      <span class="font-semibold tracking-tight text-sm hidden sm:inline">Kinetic Forms</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "text-sm font-medium transition-colors focus-visible:ring-2 ring-zinc-900 dark:ring-white rounded-sm px-1",
            pathname.startsWith(href)
              ? "text-zinc-900 dark:text-white"
              : "text-zinc-500 hover:text-zinc-900 dark:hover:text-white",
          ]}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- CTA + mobile menu button -->
    <div class="flex items-center gap-4">
      <a
        href="#newsletter"
        class="hidden sm:flex items-center px-5 min-h-[44px] bg-black dark:bg-white text-white dark:text-black text-xs font-semibold uppercase tracking-wider rounded-full hover:-translate-y-0.5 transition-all duration-150 focus-visible:ring-2 ring-zinc-900 dark:ring-white ring-offset-2"
      >
        Subscribe
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex items-center justify-center w-10 h-10 min-h-[44px] focus-visible:ring-2 ring-zinc-900 dark:ring-white rounded-sm"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-zinc-200 dark:border-zinc-800 pt-4">
    {links.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          "block py-3 text-sm font-medium transition-colors focus-visible:ring-2 ring-zinc-900 dark:ring-white rounded-sm",
          pathname.startsWith(href)
            ? "text-zinc-900 dark:text-white"
            : "text-zinc-500 hover:text-zinc-900 dark:hover:text-white",
        ]}
      >
        {label}
      </a>
    ))}
    <a
      href="#newsletter"
      class="inline-flex items-center mt-3 px-5 min-h-[44px] bg-black dark:bg-white text-white dark:text-black text-xs font-semibold uppercase tracking-wider rounded-full focus-visible:ring-2 ring-zinc-900 dark:ring-white ring-offset-2"
    >
      Subscribe
    </a>
  </div>
</nav>

<script is:inline>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const icon = document.getElementById("menu-icon");
  if (btn && menu && icon) {
    btn.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!open));
      icon.setAttribute("d", open
        ? "M4 6h16M4 12h16M4 18h16"
        : "M6 18L18 6M6 6l12 12"
      );
    });
  }
</script>
