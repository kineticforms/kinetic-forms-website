---
import Base from "../layouts/Base.astro";
import CanvasWave from "../components/CanvasWave";
import TypewriterHeading from "../components/TypewriterHeading";
import NewsletterForm from "../components/NewsletterForm";
import { getCollection } from "astro:content";
// Inline SVG icons (lucide-react can't be used in Astro templates — they're React components with hooks)

const allResearch = await getCollection("research", ({ data }) => data.status === "published");
const latestResearch = allResearch.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---

<Base title="Kinetic Forms — Intelligence in Motion">
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- HERO                                                       -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div class="relative">
    <div class="absolute top-0 left-0 w-full h-full pointer-events-none overflow-hidden z-0">
      <CanvasWave client:only="react" />
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-zinc-50/60 to-zinc-50 dark:via-black/60 dark:to-black pointer-events-none" />
    </div>

    <section class="relative z-10 pt-40 md:pt-52 pb-28 md:pb-36 px-6 max-w-6xl mx-auto">
      <TypewriterHeading client:only="react" />

      <div class="max-w-2xl mt-8 md:mt-10 space-y-5">
        <p class="text-zinc-600 dark:text-zinc-400 text-lg md:text-xl leading-relaxed">
          One builder. AI leverage. No limits.
        </p>
        <p class="text-zinc-500 text-base md:text-lg leading-relaxed">
          Kinetic Forms is where I publish the research, tools, and experiments
          that come from building software at impossible speed. If you're using AI
          to build, this is your weekly edge.
        </p>
      </div>

      <!-- Primary CTA: Newsletter -->
      <div class="mt-10 md:mt-14 max-w-md">
        <p class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-3">
          Get the weekly breakdown
        </p>
        <NewsletterForm client:only="react" />
        <p class="text-xs text-zinc-400 mt-3">
          What I built this week, how I built it, and what actually worked. No fluff.
        </p>
      </div>
    </section>
  </div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- WHAT YOU GET                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="relative z-10 bg-zinc-50 dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
    <div class="px-6 py-20 md:py-28 max-w-6xl mx-auto">
      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-12 md:mb-16">
        What you get
      </p>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        <!-- Research -->
        <div class="group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 flex items-center justify-center">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3h6M10 9V3m4 6V3M5 21h14l-2.5-9H7.5L5 21z"/></svg>
            </div>
            <h3 class="font-medium text-sm uppercase tracking-wide">Research</h3>
          </div>
          <p class="text-zinc-500 text-sm leading-relaxed mb-4">
            Deep technical deep-dives on how AI agents actually work in production.
            Not theory. Not hype. What I found by reading the source code, running
            the experiments, and building with the tools every day.
          </p>
          <a href="/research" class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors inline-flex items-center gap-1.5">
            Read research <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Tools -->
        <div class="group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 flex items-center justify-center">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <h3 class="font-medium text-sm uppercase tracking-wide">Tools</h3>
          </div>
          <p class="text-zinc-500 text-sm leading-relaxed mb-4">
            Free, open tools that I built for myself and packaged for you.
            Starting with an AI brandbook generator that creates complete brand
            identities in minutes. No login, no paywall.
          </p>
          <a href="/tools" class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors inline-flex items-center gap-1.5">
            Browse tools <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Weekly Breakdown -->
        <div class="group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-full bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 flex items-center justify-center">
              <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <h3 class="font-medium text-sm uppercase tracking-wide">Weekly Breakdown</h3>
          </div>
          <p class="text-zinc-500 text-sm leading-relaxed mb-4">
            Every week: what I shipped, the stack I used, what surprised me,
            and what I'd do differently. The kind of detail you only get from
            someone who's actually building, not just writing about building.
          </p>
          <a href="#newsletter" class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors inline-flex items-center gap-1.5">
            Subscribe <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- LATEST RESEARCH                                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="px-6 py-20 md:py-28 max-w-6xl mx-auto relative z-10 bg-zinc-50 dark:bg-black">
    <div class="flex items-baseline justify-between mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">
        Latest Research
      </p>
      <a
        href="/research"
        class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors inline-flex items-center gap-1.5"
      >
        View all <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    {latestResearch.length > 0 ? (
      <div class="space-y-4">
        {latestResearch.map((entry) => {
          const formattedDate = entry.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          return (
            <a
              href={`/research/${entry.id}`}
              class="group flex items-start justify-between gap-6 p-6 md:p-8 border border-zinc-200 dark:border-zinc-800 rounded-2xl bg-white dark:bg-zinc-900 hover:border-zinc-400 dark:hover:border-zinc-600 hover:shadow-sm transition-all duration-150 focus-visible:ring-2 ring-zinc-900 dark:ring-white"
            >
              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-lg md:text-xl mb-1.5 group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-colors">
                  {entry.data.title}
                </h3>
                <p class="text-sm text-zinc-500 leading-relaxed line-clamp-2">{entry.data.description}</p>
                <div class="flex items-center gap-3 text-xs text-zinc-400 mt-3">
                  <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
                  {entry.data.tags.length > 0 && (
                    <>
                      <span class="w-1 h-1 rounded-full bg-zinc-300" />
                      <span>{entry.data.tags.map(t => `#${t}`).join(" ")}</span>
                    </>
                  )}
                </div>
              </div>
              <div class="hidden md:flex items-center justify-center w-10 h-10 rounded-full border border-zinc-200 dark:border-zinc-700 group-hover:border-zinc-400 dark:group-hover:border-zinc-500 group-hover:bg-zinc-100 dark:group-hover:bg-zinc-800 transition-all shrink-0 mt-1">
                <svg class="w-4 h-4 text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="py-16 text-center border border-dashed border-zinc-200 dark:border-zinc-800 rounded-2xl">
        <p class="text-zinc-500 text-lg mb-2">Research is coming.</p>
        <p class="text-zinc-400 text-sm">Subscribe above to be first to read it.</p>
      </div>
    )}
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- FEATURED TOOL                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="px-6 pb-20 md:pb-28 max-w-6xl mx-auto relative z-10 bg-zinc-50 dark:bg-black">
    <div class="flex items-baseline justify-between mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">
        Coming Soon
      </p>
      <a
        href="/tools"
        class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors inline-flex items-center gap-1.5"
      >
        All tools <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <a
      href="/tools"
      class="group block relative overflow-hidden rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-zinc-900 text-white hover:border-zinc-600 transition-all duration-300 focus-visible:ring-2 ring-zinc-900 dark:ring-white"
    >
      <!-- Dark card with personality -->
      <div class="p-8 md:p-12 relative z-10">
        <div class="inline-block px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest bg-white/10 text-zinc-300 rounded-full mb-6 border border-white/10">
          Launching soon
        </div>
        <h3 class="font-medium text-2xl md:text-3xl tracking-tight mb-3">
          AI Brandbook Generator
        </h3>
        <p class="text-zinc-400 text-sm md:text-base leading-relaxed max-w-lg mb-6">
          Generate a complete brand identity in minutes. Typography, colors, voice,
          logo direction, motion guidelines. The same tool I used to build Kinetic
          Forms' brand. Now yours, for free.
        </p>
        <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-zinc-300 group-hover:text-white transition-colors">
          Get notified when it launches <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </div>
      <!-- Subtle grid pattern overlay -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;" />
    </a>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- ABOUT TEASER                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="relative z-10 bg-zinc-50 dark:bg-black border-t border-zinc-200 dark:border-zinc-800">
    <div class="px-6 py-20 md:py-28 max-w-6xl mx-auto">
      <div class="max-w-2xl">
        <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-6">
          Who's behind this
        </p>
        <p class="text-xl md:text-2xl font-medium tracking-tight leading-snug mb-4">
          I'm Chris. I build things with AI from Puerto Rico.
        </p>
        <p class="text-zinc-500 text-base leading-relaxed mb-6">
          One person, AI leverage, and the conviction that a single builder can now
          ship what used to take a team. Everything on this site exists because I
          needed it first. The tools are real, the research is from the source, and
          the weekly breakdowns are the notes I'd send to a friend.
        </p>
        <a
          href="/about"
          class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors inline-flex items-center gap-1.5"
        >
          More about Kinetic Forms <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- NEWSLETTER (reinforcement)                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section id="newsletter" class="bg-zinc-900 dark:bg-zinc-800 text-white px-6 py-20 md:py-28">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-4">
        Build faster. Ship more.
      </h2>
      <p class="text-zinc-400 text-base mb-10 leading-relaxed max-w-lg mx-auto">
        Every week I share exactly what I built, the tools and techniques that
        worked, and the mistakes that didn't. For builders who want the real
        playbook, not the hype.
      </p>
      <div class="max-w-md mx-auto">
        <NewsletterForm client:only="react" variant="dark" />
      </div>
      <p class="text-xs text-zinc-500 mt-4">
        Join builders who are shipping with AI. Unsubscribe anytime.
      </p>
    </div>
  </section>
</Base>
