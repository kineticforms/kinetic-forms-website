---
import Base from "../../layouts/Base.astro";
import NewsletterForm from "../../components/NewsletterForm";
import { getCollection } from "astro:content";

const allResearch = await getCollection("research", ({ data }) => data.status === "published");
const sorted = allResearch.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Research — Kinetic Forms" description="Deep technical research on AI-native development, agent architecture, and building with AI.">
  <div class="pt-32 pb-24 px-6 max-w-6xl mx-auto">
    <div class="mb-12">
      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4">Research</p>
      <h1 class="text-4xl md:text-5xl font-medium tracking-tight">Deep-dives</h1>
      <p class="text-lg text-zinc-500 mt-4 max-w-2xl leading-relaxed">
        Technical research on AI-native development, agent architecture, and what actually works when you're building with AI.
      </p>
    </div>

    {sorted.length > 0 ? (
      <div class="space-y-6">
        {sorted.map((entry) => {
          const formattedDate = entry.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
          return (
            <a
              href={`/research/${entry.id}`}
              class="block p-8 border border-zinc-200 dark:border-zinc-800 rounded-2xl bg-white dark:bg-zinc-900 hover:border-zinc-400 dark:hover:border-zinc-600 transition-all duration-150 focus-visible:ring-2 ring-zinc-900 dark:ring-white group"
            >
              <h2 class="font-medium text-xl mb-2 group-hover:text-zinc-700 dark:group-hover:text-zinc-300 transition-colors">
                {entry.data.title}
              </h2>
              <p class="text-sm text-zinc-500 mb-3">{entry.data.description}</p>
              <div class="flex items-center gap-3 text-xs text-zinc-400">
                <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
                {entry.data.tags.length > 0 && (
                  <>
                    <span>·</span>
                    <span>{entry.data.tags.map(t => `#${t}`).join(" ")}</span>
                  </>
                )}
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-24">
        <p class="text-zinc-500 text-lg mb-6">Research is coming. Subscribe to be first to read it.</p>
        <div class="max-w-md mx-auto">
          <NewsletterForm client:only="react" />
        </div>
      </div>
    )}
  </div>
</Base>
